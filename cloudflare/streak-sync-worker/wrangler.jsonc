{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dbd-streak-sync",
  "main": "src/index.js",
  "compatibility_date": "2026-06-29",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "d1_databases": [
    {
      "binding": "STREAK_DB",
      "database_name": "dbd-streak-sync",
      "database_id": "replace-with-your-d1-database-id"
    }
  ]
}
